# API
API_URL=https://xxxxxxxxxx.execute-api.eu-central-1.amazonaws.com/prod/chat

# Data
DATA_FOLDER=MyData

# Portfolio
PORTFOLIO_OWNER=John Doe

# AWS
BEDROCK_REGION=us-east-1
S3_BUCKET=your-portfolio-bucket

# FAISS Index
S3_INDEX_KEY=faiss/index

# Bedrock
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
LLM_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Retrieval
TOP_K=5
